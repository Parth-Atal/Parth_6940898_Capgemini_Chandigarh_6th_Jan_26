@page
@model EventBooking.Web.Pages.MyBookingsModel
@{
    ViewData["Title"] = "My Bookings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-ticket-perforated"></i> My Bookings</h2>
    <a href="/Events" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Book More
    </a>
</div>

<div id="bookingsAlert" class="alert d-none"></div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle" id="bookingsTable">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Event</th>
                <th>Seats</th>
                <th>Booked On</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody id="bookingsBody">
            <tr>
                <td colspan="5" class="text-center py-4">
                    <div class="spinner-border text-primary"></div>
                </td>
            </tr>
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        loadMyBookings();
    </script>
}
