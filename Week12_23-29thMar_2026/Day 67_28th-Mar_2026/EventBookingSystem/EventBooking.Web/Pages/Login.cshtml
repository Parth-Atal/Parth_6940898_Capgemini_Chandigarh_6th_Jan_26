@page
@using System.Security.Cryptography
@model EventBooking.Web.Pages.LoginModel
@{
    ViewData["Title"] = "Login / Register";
}

<style>
    body {
        background: linear-gradient(135deg, #4e73df, #1cc88a);
        min-height: 100vh;
    }

    .auth-container {
        min-height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .auth-card {
        border: none;
        border-radius: 20px;
        backdrop-filter: blur(10px);
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 8px 30px rgba(0,0,0,0.2);
        transition: 0.3s;
    }

    .auth-card:hover {
        transform: translateY(-5px);
    }

    .card-header {
        border-top-left-radius: 20px !important;
        border-top-right-radius: 20px !important;
        font-weight: 600;
    }

    .form-control {
        border-radius: 10px;
        padding: 10px;
        transition: 0.2s;
    }

    .form-control:focus {
        border-color: #4e73df;
        box-shadow: 0 0 8px rgba(78,115,223,0.3);
    }

    .btn {
        border-radius: 25px;
        padding: 10px;
        font-weight: 500;
        transition: 0.3s;
    }

    .btn:hover {
        transform: scale(1.05);
    }

    .title {
        text-align: center;
        color: white;
        font-weight: 600;
        margin-bottom: 20px;
    }
    }
</style>

<div class="container auth-container">

    <div class="w-100">

        <h2 class="title">
            <i class="bi bi-calendar-check"></i> Event Booking System
        </h2>

        <div class="row justify-content-center">

            <!-- LOGIN -->
            <div class="col-md-5 mb-4">
                <div class="card auth-card">

                    <div class="card-header bg-primary text-white text-center">
                        <h5 class="mb-0">
                            <i class="bi bi-box-arrow-in-right"></i> Login
                        </h5>
                    </div>

                    <div class="card-body">

                        <div id="loginAlert" class="alert d-none"></div>

                        <div class="mb-3">
                            <label>Email</label>
                            <input type="email" id="loginEmail" class="form-control" placeholder="you@example.com"/>
                        </div>

                        <div class="mb-3">
                            <label>Password</label>
                            <input type="password" id="loginPassword" class="form-control" placeholder="Password"/>
                        </div>

                        <button class="btn btn-primary w-100" onclick="loginUser()">
                            <i class="bi bi-box-arrow-in-right"></i> Login
                        </button>

                    </div>

                </div>
            </div>

            <!-- REGISTER -->
            <div class="col-md-5">
                <div class="card auth-card">

                    <div class="card-header bg-success text-white text-center">
                        <h5 class="mb-0">
                            <i class="bi bi-person-plus"></i> Register
                        </h5>
                    </div>

                    <div class="card-body">

                        <div id="registerAlert" class="alert d-none"></div>

                        <div class="mb-3">
                            <label>Full Name</label>
                            <input type="text" id="regName" class="form-control" placeholder="Your Name"/>
                        </div>

                        <div class="mb-3">
                            <label>Email</label>
                            <input type="email" id="regEmail" class="form-control" placeholder="you@example.com"/>
                        </div>

                        <div class="mb-3">
                            <label>Password</label>
                            <input type="password" id="regPassword" class="form-control" placeholder="Min 6 characters"/>
                        </div>

                        <button class="btn btn-success w-100" onclick="registerUser()">
                            <i class="bi bi-person-plus"></i> Register
                        </button>

                    </div>

                </div>
            </div>

        </div>

    </div>

</div>