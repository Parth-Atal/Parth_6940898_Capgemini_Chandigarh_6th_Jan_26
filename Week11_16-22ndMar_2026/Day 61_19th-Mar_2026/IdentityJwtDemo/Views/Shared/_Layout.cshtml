<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IdentityJwtDemo</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/IdentityJwtDemo.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark px-3">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                Identity + JWT Demo
            </a>

            <div class="ms-auto">

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <span class="text-white me-3">
                        👤 @User.Identity.Name
                    </span>

                    <a class="btn btn-warning me-2" asp-controller="Home" asp-action="Dashboard">
                        Dashboard
                    </a>

                    <form method="post" asp-area="Identity" asp-page="/Account/Logout" style="display:inline;">
                        <button type="submit" class="btn btn-danger">
                            Logout
                        </button>
                    </form>
                }
                else
                {
                    <a class="btn btn-success me-2" asp-area="Identity" asp-page="/Account/Register">
                        Register
                    </a>

                    <a class="btn btn-primary me-2" asp-area="Identity" asp-page="/Account/Login">
                        Login
                    </a>
                }

            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - IdentityJwtDemo - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
