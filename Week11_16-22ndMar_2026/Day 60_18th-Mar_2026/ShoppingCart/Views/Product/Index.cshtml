@model List<ShoppingCartMvc.Models.Product>

<h2 class="mb-4">🛍 Products</h2>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-3 mb-4">
            <div class="card shadow h-100">
                <img src="@item.ImageUrl" class="card-img-top" style="height:180px; object-fit:cover;" />

                <div class="card-body text-center">
                    <h5>@item.Name</h5>
                    <p class="text-success fw-bold">₹@item.Price</p>

                    <a asp-controller="Cart" asp-action="Add" asp-route-id="@item.Id"
                       class="btn btn-primary w-100 mb-2">
                        Add to Cart
                    </a>

                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                </div>
            </div>
        </div>
    }
</div>