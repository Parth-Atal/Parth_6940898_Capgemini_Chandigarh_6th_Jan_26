@model Order

<h2 class="mb-4">📦 Order Details</h2>

<div class="card p-4">

    <div class="d-flex justify-content-between">
        <h5>Order ID: @Model.OrderId</h5>
        <span class="badge bg-secondary">
            @Model.OrderDate.ToShortDateString()
        </span>
    </div>

    <hr />

    <h5>👤 Customer</h5>
    <p>@Model.Customer?.Name</p>

    <h5 class="mt-3">🛍️ Products</h5>

    <ul class="list-group mb-3">
        @foreach (var item in Model.OrderItems)
        {
            <li class="list-group-item d-flex justify-content-between">
                @item.Product?.Name
                <span class="badge bg-primary">Qty: @item.Quantity</span>
            </li>
        }
    </ul>

    <h5>🚚 Shipping</h5>
    <p><strong>Address:</strong> @Model.ShippingDetail?.Address</p>

    <p>
        <strong>Status:</strong>
        <span class="badge @(Model.ShippingDetail?.Status == "Pending" ? "bg-warning" : "bg-success")">
            @Model.ShippingDetail?.Status
        </span>
    </p>

</div>

<a href="/Product" class="btn btn-primary mt-3">Back to Products</a>