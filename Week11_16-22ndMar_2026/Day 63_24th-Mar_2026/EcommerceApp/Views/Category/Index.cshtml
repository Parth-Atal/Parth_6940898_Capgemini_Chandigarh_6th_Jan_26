@model IEnumerable<Category>

<h2 class="mb-4">📂 Categories</h2>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-3 mb-4">
            <div class="card p-3 text-center">
                <h5 class="fw-bold">@item.Name</h5>

                <div class="mt-3">
                    <a href="/Category/Edit/@item.CategoryId" class="btn btn-sm btn-warning">Edit</a>
                    <a href="/Category/Delete/@item.CategoryId" class="btn btn-sm btn-danger">Delete</a>
                </div>
            </div>
        </div>
    }
</div>

<a href="/Category/Create" class="btn btn-primary">+ Add Category</a>