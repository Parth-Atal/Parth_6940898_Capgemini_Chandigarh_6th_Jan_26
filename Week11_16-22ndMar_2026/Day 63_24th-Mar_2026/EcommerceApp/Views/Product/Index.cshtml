@model IEnumerable<Product>

<h2 class="mb-4">🛍️ Products</h2>

<form method="get" class="mb-4">
    <select name="categoryId" class="form-select w-25 d-inline">
        <option value="">All Categories</option>
        @foreach (var cat in ViewBag.Categories)
        {
            <option value="@cat.CategoryId">@cat.Name</option>
        }
    </select>

    <button class="btn btn-primary ms-2">Filter</button>
</form>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-3 mb-4">
            <div class="card p-3">
                <h5>@item.Name</h5>
                <p class="text-muted">@item.Category?.Name</p>

                <h6 class="text-success">₹@item.Price</h6>

                <div class="mt-3 d-flex justify-content-between">
                    <a href="/Product/Edit/@item.ProductId" class="btn btn-sm btn-warning">Edit</a>
                    <a href="/Product/Delete/@item.ProductId" class="btn btn-sm btn-danger">Delete</a>
                </div>
            </div>
        </div>
    }
</div>

<a href="/Product/Create" class="btn btn-primary">+ Add Product</a>