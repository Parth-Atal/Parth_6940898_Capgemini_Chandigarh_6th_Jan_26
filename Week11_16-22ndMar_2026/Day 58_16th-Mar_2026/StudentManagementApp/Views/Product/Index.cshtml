@model List<StudentManagementApp.Models.Product>

<h2>Product List</h2>

<a asp-action="Create" class="btn btn-success mb-3">Add Product</a>

<table class="table table-bordered table-striped">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Actions</th>
    </tr>

    @foreach (var p in Model)
    {
        <tr>
            <td>@p.Id</td>
            <td>@p.Name</td>
            <td>
                <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-info btn-sm">View</a>
            </td>
        </tr>
    }
</table>