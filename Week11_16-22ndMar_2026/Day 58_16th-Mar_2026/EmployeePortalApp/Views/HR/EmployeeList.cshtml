@model List<EmployeePortalApp.Models.Employee>

@{
    ViewData["Title"] = "Employee List";
}

<h2>Employee List</h2>

<hr />

@if (Model.Count == 0)
{
    <p>No employees registered yet.</p>
}
else
{
    <table class="table table-bordered">
        <tr>
            <th>Name</th>
            <th>Age</th>
            <th>Email</th>
            <th>Department</th>
        </tr>

        @foreach (var e in Model)
        {
            <tr>
                <td>@e.Name</td>
                <td>@e.Age</td>
                <td>@e.Email</td>
                <td>@e.Department</td>
            </tr>
        }
    </table>
}

<br />

<a asp-action="Index" class="btn btn-secondary">Back</a>