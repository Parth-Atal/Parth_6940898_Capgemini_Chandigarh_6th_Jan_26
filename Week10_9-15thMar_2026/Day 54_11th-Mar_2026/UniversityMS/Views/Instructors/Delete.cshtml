@model UniversityMS.Models.Instructor
@{
    ViewData["Title"] = "Delete Instructor";
}

<h2>Delete Instructor</h2>
<p class="text-danger fw-bold">Are you sure you want to delete this instructor?</p>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Department</dt>
    <dd class="col-sm-9">@Model.Department?.Name</dd>
</dl>

<div class="alert alert-warning">
    ⚠️ Deleting this instructor may affect assigned courses.
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="InstructorId" />
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>