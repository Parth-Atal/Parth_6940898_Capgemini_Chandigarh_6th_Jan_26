@model UniversityMS.Models.Instructor
@{
    ViewData["Title"] = "Instructor Details";
}

<h2>@Model.Name</h2>
<dl class="row">
    <dt class="col-sm-3">Department</dt>
    <dd class="col-sm-9">@Model.Department?.Name</dd>
</dl>

<h4>Courses Taught</h4>
@if (Model.Courses != null && Model.Courses.Any())
{
    <table class="table table-sm table-bordered">
        <thead class="table-light">
            <tr><th>Course Title</th><th>Credits</th></tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Courses)
            {
                <tr>
                    <td>@c.Title</td>
                    <td>@c.Credits</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No courses assigned to this instructor.</p>
}

<a asp-action="Edit" asp-route-id="@Model.InstructorId" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>