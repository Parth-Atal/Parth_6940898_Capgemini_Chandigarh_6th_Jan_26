@model UniversityMS.Models.Student
@{
    ViewData["Title"] = "Student Details";
}

<h2>@Model.FullName</h2>
<dl class="row">
    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>
    <dt class="col-sm-3">Enrolled</dt>
    <dd class="col-sm-9">@Model.EnrollmentDate.ToShortDateString()</dd>
</dl>

<h4>Enrolled Courses</h4>
<table class="table table-sm">
    <thead><tr><th>Course</th><th>Credits</th><th>Grade</th></tr></thead>
    <tbody>
        @foreach (var e in Model.Enrollments ?? new List<UniversityMS.Models.Enrollment>())
        {
            <tr>
                <td>@e.Course?.Title</td>
                <td>@e.Course?.Credits</td>
                <td>@(e.Grade ?? "—")</td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Edit" asp-route-id="@Model.StudentId" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>