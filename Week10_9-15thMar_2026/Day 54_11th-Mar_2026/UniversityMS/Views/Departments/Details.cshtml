@model UniversityMS.Models.Department
@{
    ViewData["Title"] = "Department Details";
}

<h2>@Model.Name</h2>
<dl class="row">
    <dt class="col-sm-3">Budget</dt>
    <dd class="col-sm-9">@Model.Budget.ToString("C")</dd>
</dl>

<h4>Instructors in this Department</h4>
@if (Model.Instructors != null && Model.Instructors.Any())
{
    <table class="table table-sm table-bordered">
        <thead class="table-light">
            <tr><th>#</th><th>Instructor Name</th></tr>
        </thead>
        <tbody>
            @{
                int row = 1;
            }
            @foreach (var inst in Model.Instructors)
            {
                <tr>
                    <td>@(row++)</td>
                    <td>@inst.Name</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No instructors assigned to this department.</p>
}

<a asp-action="Edit" asp-route-id="@Model.DepartmentId" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>