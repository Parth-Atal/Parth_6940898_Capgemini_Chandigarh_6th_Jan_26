@model IEnumerable<UniversityMS.Models.Department>
@{
    ViewData["Title"] = "Departments";
}

<h2>Departments</h2>
<p><a asp-action="Create" class="btn btn-primary">+ New Department</a></p>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Department Name</th>
            <th>Budget</th>
            <th>No. of Instructors</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in Model)
        {
            <tr>
                <td>@d.Name</td>
                <td>@d.Budget.ToString("C")</td>
                <td>
                    <span class="badge bg-primary">
                        @(d.Instructors?.Count ?? 0)
                    </span>
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@d.DepartmentId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@d.DepartmentId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@d.DepartmentId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>