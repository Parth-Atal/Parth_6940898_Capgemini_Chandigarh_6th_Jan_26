@model UniversityMS.Models.Department
@{
    ViewData["Title"] = "Delete Department";
}

<h2>Delete Department</h2>
<p class="text-danger fw-bold">Are you sure you want to delete this department?</p>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Budget</dt>
    <dd class="col-sm-9">@Model.Budget.ToString("C")</dd>
    <dt class="col-sm-3">Instructors</dt>
    <dd class="col-sm-9">@(Model.Instructors?.Count ?? 0) instructor(s) will be affected</dd>
</dl>

<div class="alert alert-danger">
    ⚠️ Deleting this department will affect all linked instructors.
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="DepartmentId" />
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>