@model UniversityMS.Models.Course
@{
    ViewData["Title"] = "Delete Course";
}

<h2>Delete Course</h2>
<p class="text-danger fw-bold">Are you sure you want to delete this course?</p>

<dl class="row">
    <dt class="col-sm-3">Title</dt>
    <dd class="col-sm-9">@Model.Title</dd>

    <dt class="col-sm-3">Credits</dt>
    <dd class="col-sm-9">@Model.Credits</dd>

    <dt class="col-sm-3">Instructor</dt>
    <dd class="col-sm-9">@Model.Instructor?.Name</dd>
</dl>

<div class="alert alert-warning">
    ⚠️ Deleting this course will also remove all related enrollments.
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="CourseId" />
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>